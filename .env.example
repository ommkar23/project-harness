HARNESS_EXECUTION_TIMEOUT_MS=120000
HARNESS_EXECUTION_OUTPUT_LIMIT=12000

# Optional private repo auth
HARNESS_REPO_GIT_PASSWORD=

# Optional repo-local helper providers forwarded into the sandbox
